# ============================================
# Chat Corporativo — Variables de Entorno
# ============================================

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=chat_corporativo
MYSQL_USER=chatuser
MYSQL_PASSWORD=TU_PASSWORD_AQUI
MYSQL_ROOT_PASSWORD=TU_ROOT_PASSWORD_AQUI

# Backend
NODE_ENV=production
PORT=5000
JWT_SECRET=CAMBIAR_POR_UN_SECRET_SEGURO
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_SECRET_SEGURO
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database URL (Prisma)
DATABASE_URL=mysql://chatuser:TU_PASSWORD_AQUI@mysql:3306/chat_corporativo
